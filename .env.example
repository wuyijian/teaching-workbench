# ══════════════════════════════════════════════
# ── 微信开放平台（可选，不填则不显示微信登录按钮）──
# 1. 前往 https://open.weixin.qq.com → 管理中心 → 网站应用 → 创建应用
# 2. 通过审核后获取 AppID 和 AppSecret
# 3. 在「开发信息」中配置授权回调域（填域名，不含 https://，例如 your-app.vercel.app）
# 4. AppSecret 配置到 Supabase Edge Functions Secrets（不要暴露在前端！）
VITE_WECHAT_APP_ID=wx_your_appid_here

# ── Supabase 登录注册（可选，不填则跳过 auth，适用于 Electron 桌面端）──
# 1. 前往 https://supabase.com/dashboard 新建项目（免费）
# 2. Project Settings → API，复制 Project URL 和 anon public key
# 3. Authentication → Providers → Email，可关闭「Confirm email」简化注册流程
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── 网页版（npm run build:web）默认 base=/ ──
# 子路径部署示例：VITE_BASE_URL=/teaching/

# ── 讯飞转写反代前缀（与 Nginx / Vercel 的 /xfyun-api 一致）──
# VITE_XFYUN_PROXY_BASE=/xfyun-api

# ── 平台讯飞 API Key（SaaS 模式：用户无需自备，统一由平台管理）──
# 1. 前往 https://www.xfyun.cn → 控制台 → 创建应用 → 录音文件转写（标准版）
# 2. 获取 AppID、AccessKeyID、AccessKeySecret
# 3. 本地开发填入下方；生产环境在 Vercel / Netlify Dashboard → Environment Variables 中配置
# 填写后，用户设置界面将自动隐藏讯飞配置项（平台统一托管）
VITE_XF_APP_ID=your_xfyun_app_id
VITE_XF_ACCESS_KEY_ID=your_xfyun_access_key_id
VITE_XF_ACCESS_KEY_SECRET=your_xfyun_access_key_secret

# ── OpenAI 兼容接口：网页版走同域反代 /openai-api/v1，需在网关反代到 https://api.openai.com ──

# ── Electron 桌面端：npm run build:electron，勿手改 VITE_ELECTRON ──
