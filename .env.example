# ══════════════════════════════════════════════
# ── 微信开放平台（可选，不填则不显示微信登录按钮）──
# 1. 前往 https://open.weixin.qq.com → 管理中心 → 网站应用 → 创建应用
# 2. 通过审核后获取 AppID 和 AppSecret
# 3. 在「开发信息」中配置授权回调域（填域名，不含 https://，例如 your-app.vercel.app）
# 4. AppSecret 配置到 Supabase Edge Functions Secrets（不要暴露在前端！）
VITE_WECHAT_APP_ID=wx_your_appid_here

# ── Supabase 登录注册（可选，不填则跳过 auth，适用于 Electron 桌面端）──
# 1. 前往 https://supabase.com/dashboard 新建项目（免费）
# 2. Project Settings → API，复制 Project URL 和 anon public key
# 3. Authentication → Providers → Email，可关闭「Confirm email」简化注册流程
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── 网页版（npm run build:web）默认 base=/ ──
# 子路径部署示例：VITE_BASE_URL=/teaching/

# ── 讯飞转写反代前缀（与 Nginx / Vercel 的 /xfyun-api 一致）──
# VITE_XFYUN_PROXY_BASE=/xfyun-api

# ── 讯飞转写（仅服务端/构建时配置，用户界面不再填写）──
# 1. 前往 https://www.xfyun.cn → 录音文件转写（标准版）
# 2. 本地与生产均在环境变量中配置，打包进静态资源，勿提交 git
VITE_XF_APP_ID=your_xfyun_app_id
VITE_XF_ACCESS_KEY_ID=your_xfyun_access_key_id
VITE_XF_ACCESS_KEY_SECRET=your_xfyun_access_key_secret

# ── 大模型 API（Kimi / OpenAI 兼容，仅服务端/构建时配置）──
# 网页版需同域反代，默认基址为 /openai-api/v1，也可直填 https://api.moonshot.cn/v1
# VITE_LLM_BASE_URL=/openai-api/v1
VITE_LLM_API_KEY=sk-your-llm-key
VITE_LLM_MODEL=kimi-k2.5

# ── 说明：旧版在「设置」里填 Key 已移除；只保留用户可改的「反馈 Prompt」在设置中 ──
# ── OpenAI 兼容：网页走同域反代 /openai-api/v1，需在网关反代到目标 API ──

# ── Electron 桌面端：npm run build:electron，勿手改 VITE_ELECTRON ──

# ══════════════════════════════════════════════
# ── 管理员脚本专用（gen-redeem-codes.mjs / test-redeem.mjs，仅本机使用）──
# ⚠️ 这些 key 永远不要进 git，永远不要进前端构建（没有 VITE_ 前缀）
#
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...                  # service_role，上帝权限
# SUPABASE_ANON_KEY=eyJ...                          # 仅 test-redeem.mjs 用
#
# 用法示例：
#   $env:SUPABASE_URL = "..."
#   $env:SUPABASE_SERVICE_ROLE_KEY = "..."
#   node scripts/gen-redeem-codes.mjs --plan pro --count 10 --days 30
