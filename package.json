{
  "name": "teaching-workbench",
  "productName": "语文教学工作台",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build",
    "build:electron": "tsc -b && cross-env VITE_ELECTRON=1 vite build",
    "build:web:pack": "npm run build:web && node scripts/zip-web.mjs",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env VITE_ELECTRON=1 NODE_ENV=development vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build:electron && cross-env NODE_ENV=production electron-builder --mac",
    "electron:build:mac": "npm run build:electron && cross-env NODE_ENV=production electron-builder --mac",
    "electron:build:dir": "npm run build:electron && cross-env NODE_ENV=production electron-builder --mac --dir",
    "electron:build:win": "npm run build:electron && cross-env NODE_ENV=production electron-builder --win --x64",
    "smoke": "node scripts/release-smoke.mjs",
    "smoke:xfyun": "node scripts/xfyun-smoke.mjs",
    "smoke:llm": "node scripts/llm-smoke.mjs",
    "release:patch": "node scripts/release-tag.mjs patch",
    "release:minor": "node scripts/release-tag.mjs minor",
    "release:major": "node scripts/release-tag.mjs major"
  },
  "build": {
    "appId": "com.teaching.workbench",
    "productName": "语文教学工作台",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build-assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build-assets/entitlements.mac.plist",
      "entitlementsInherit": "build-assets/entitlements.mac.plist"
    },
    "dmg": {
      "title": "语文教学工作台",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.2.4",
    "lucide-react": "^1.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
