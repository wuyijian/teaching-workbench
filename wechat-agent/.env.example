# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# 用 service_role key（在 Supabase 控制台 → Settings → API）
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── LLM（Kimi/Moonshot）────────────────────────────────────────────────
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2.5

# ── 讯飞转写（可选，暂未启用）─────────────────────────────────────────
XF_APP_ID=
XF_ACCESS_KEY_ID=
XF_ACCESS_KEY_SECRET=

# ── 安全白名单（可选）────────────────────────────────────────────────
# 逗号分隔的微信 openid，留空则任何人都可使用
ALLOWED_OPENIDS=

# ── 端口 ──────────────────────────────────────────────────────────────
PORT=18080
